# Порт сервера
PORT=3000

# ЮKassa
# ShopID: 1299171
# API ключ (используется и для создания платежей, и для проверки webhook подписей)
YOOKASSA_SECRET_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Внутренний API вашего бота (опционально)
# Если ваш бот имеет свой API для предоставления доступа
BOT_INTERNAL_API_URL=http://localhost:8000/api

# Логирование
LOG_LEVEL=info
